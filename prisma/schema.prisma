generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String?
  price          Int
  compareAtPrice Int            @default(0)
  rating         Float          @default(0)
  reviewCount    Int            @default(0)
  category       String
  inStock        Boolean        @default(true)
  badge          String?
  image          String
  images         ProductImage[]
  specs          ProductSpec[]
  testimonials   Testimonial[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  src       String
  alt       String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model ProductSpec {
  id        String   @id @default(cuid())
  productId String
  label     String
  value     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model Testimonial {
  id        String   @id @default(cuid())
  productId String?
  name      String
  location  String?
  rating    Int
  quote     String
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  topic       String
  orderNumber String?
  message     String
  createdAt   DateTime @default(now())
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
